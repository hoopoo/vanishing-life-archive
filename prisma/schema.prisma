generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model SeedKeyword {
  id        Int      @id @default(autoincrement())
  keyword   String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Video {
  id              Int       @id @default(autoincrement())
  videoId         String    @unique
  url             String
  title           String
  description     String    @default("")
  channelTitle    String
  publishedAt     DateTime
  thumbnailUrl    String    @default("")
  duration        String    @default("")
  viewCount       Int       @default(0)
  likeCount       Int       @default(0)
  commentCount    Int       @default(0)
  seedKeyword     String
  rawJson         String    @default("{}")
  curationStatus  String    @default("unreviewed")
  humanNote       String?
  publicNote      String?
  publishStatus   String    @default("private")
  isFeatured      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  analysis        Analysis?
  clusterItems    ClusterItem[]
}

model Analysis {
  id                          Int      @id @default(autoincrement())
  videoId                     String   @unique
  category                    String
  vanishingLifeScore          Int
  scoresJson                  String
  observe                     String
  sample                      String
  recombine                   String
  question                    String
  fieldNoteTitle              String
  fieldNote                   String
  tagsJson                    String
  articleAngle                String?
  articleTitleCandidatesJson  String?
  model                       String
  publishStatus               String   @default("private")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  video                       Video    @relation(fields: [videoId], references: [videoId])
}

model ArticleDraft {
  id                   Int                @id @default(autoincrement())
  title                String
  subtitle             String             @default("")
  theme                String             @default("")
  angle                String             @default("")
  lead                 String             @default("")
  outlineJson          String             @default("[]")
  selectedVideoIdsJson String             @default("[]")
  bodyDraft            String             @default("")
  questionsJson        String             @default("[]")
  tagsJson             String             @default("[]")
  titleCandidatesJson  String?
  linkedinPost         String?
  noteIntro            String?
  status               String             @default("draft")
  publishStatus        String             @default("private")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  revisions            ArticleRevision[]
}

model ArticleRevision {
  id             Int          @id @default(autoincrement())
  articleDraftId Int
  actionType     String
  beforeJson     String
  afterJson      String
  createdAt      DateTime     @default(now())
  articleDraft   ArticleDraft @relation(fields: [articleDraftId], references: [id], onDelete: Cascade)
}

model Cluster {
  id                     Int           @id @default(autoincrement())
  title                  String
  description            String        @default("")
  theme                  String        @default("")
  question               String        @default("")
  tagsJson               String        @default("[]")
  summary                String?
  hypothesis             String?
  articleAnglesJson      String?
  generatedQuestionsJson String?
  recommendedTitle       String?
  publishStatus          String        @default("private")
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  items                  ClusterItem[]
}

model ClusterItem {
  id        Int      @id @default(autoincrement())
  clusterId Int
  videoId   Int
  note      String?
  createdAt DateTime @default(now())
  cluster   Cluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([clusterId, videoId])
}
